# ── Supabase connection ─────────────────────────────────────
# The app stores its data in the isolated "cub_scouts" schema of your
# "Calendar App 2026" Supabase project. The calendar's own tables
# (public.events) are never touched.
#
# Get the connection string from:
#   Supabase Dashboard > Calendar App 2026 > Connect > Session pooler
# Replace [YOUR-PASSWORD] with your database password
# (Settings > Database > Reset database password if you don't have it)
DATABASE_URL=postgresql://postgres.ahdcdasfqhqsimxmfpkj:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# ── Flask session signing key ───────────────────────────────
# Required on Vercel (otherwise logins drop on every cold start).
# Set to any long random string.
SECRET_KEY=change-me-to-a-long-random-string

# Leave DATABASE_URL empty/unset to fall back to local SQLite (scouts.db)
